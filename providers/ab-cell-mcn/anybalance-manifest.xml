<?xml version="1.0" encoding="utf-8"?>
<provider>
	<id version="2">ab-cell-mcn</id>
	<api flags="no_browser"/>
	<name>MCN Телеком</name>
	<description html="true"><![CDATA[
	<p>Предоставляет информацию о текущем балансе и другие данные для абонентов провайдера MCN Телеком (https://www.mcn.ru/).</p>
	<p>Информация берется из личного кабинета MCN Телеком на сайте <a href="https://base.mcn.ru/">https://base.mcn.ru/</a> или на сайте <a href="https://lk.mcn.ru/">https://lk.mcn.ru/</a>.</p>
	]]></description>
	<instruction html="true"><![CDATA[
	<p>Для работы провайдера требуется ввести логин и пароль для входа в личный кабинет MCN Телеком.</p>
	<p>Если у вас нет личного кабинета MCN Телеком, вы можете зарегистрировать его на сайте https://shop.mcn.ru/.</p>
	]]></instruction>
	<author>AnyBalance Team &lt;info@anybalance.ru&gt;</author>
	<depends>
		<module id="library"/>
	</depends>
	<files>
		<icon>icon.png</icon>
		<preferences>preferences.xml</preferences>
		<js>main.js</js>
		<history>history.xml</history>
	</files>
	<counters>
		<counter id="balance" name="Баланс" units=" ₽"/>
		<counter id="credit" name="Кредитный лимит" units=" ₽"/>
		<counter id="ls" name="Лицевой счет" type="text"/>
		<counter id="tel0" name="1.Номер телефона" type="text"/>
		<counter id="tel1" name="2.Номер телефона" type="text"/>
		<counter id="tel2" name="3.Номер телефона" type="text"/>
		<counter id="tel3" name="4.Номер телефона" type="text"/>
		<counter id="tel4" name="5.Номер телефона" type="text"/>
		<counter id="inet0" name="1.Трафик" prefix="{@pretel0}" suffix="{@suf_inet0}" units=" Мб"/>
		<counter id="inet1" name="2.Трафик" prefix="{@pretel1}" suffix="{@suf_inet1}" units=" Мб"/>
		<counter id="inet2" name="3.Трафик" prefix="{@pretel2}" suffix="{@suf_inet2}" units=" Мб"/>
		<counter id="inet3" name="4.Трафик" prefix="{@pretel3}" suffix="{@suf_inet3}" units=" Мб"/>
		<counter id="inet4" name="5.Трафик" prefix="{@pretel4}" suffix="{@suf_inet4}" units=" Мб"/>
		<counter id="deactivate_future_date0" name="1.Отключение" prefix="{@pretel0}" type="time" format="dd.MM.YYYY"/>
		<counter id="deactivate_future_date1" name="2.Отключение" prefix="{@pretel1}" type="time" format="dd.MM.YYYY"/>
		<counter id="deactivate_future_date2" name="3.Отключение" prefix="{@pretel2}" type="time" format="dd.MM.YYYY"/>
		<counter id="deactivate_future_date3" name="4.Отключение" prefix="{@pretel3}" type="time" format="dd.MM.YYYY"/>
		<counter id="deactivate_future_date4" name="5.Отключение" prefix="{@pretel4}" type="time" format="dd.MM.YYYY"/>
		<counter id="tariff0" name="1.Тариф" prefix="{@pretel0}" type="text"/>
		<counter id="tariff1" name="2.Тариф" prefix="{@pretel1}" type="text"/>
		<counter id="tariff2" name="3.Тариф" prefix="{@pretel2}" type="text"/>
		<counter id="tariff3" name="4.Тариф" prefix="{@pretel3}" type="text"/>
		<counter id="tariff4" name="5.Тариф" prefix="{@pretel4}" type="text"/>
		<counter id="email" name="E-mail" type="text"/>
		<counter id="fio" name="ФИО" type="text"/>
	</counters>
	<keywords></keywords>
	<type>cell</type>
	<country>ru</country>
</provider>
